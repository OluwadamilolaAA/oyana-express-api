{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/oyana-express-api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
