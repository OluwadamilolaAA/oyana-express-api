# MongoDB root credentials (used by the mongo container in docker-compose)
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=secret

# JWT (required)
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

AUTH_GRPC_URL=localhost:50051
USER_GRPC_URL=localhost:50052
DRIVER_GRPC_URL=localhost:50053

AUTH_GRPC_BIND_URL=0.0.0.0:50051
USER_GRPC_BIND_URL=0.0.0.0:50052
DRIVER_GRPC_BIND_URL=0.0.0.0:50053

GATEWAY_HTTP_PORT=3000
AUTH_HTTP_PORT=3001
USER_HTTP_PORT=3002
DRIVER_HTTP_PORT=3003

# Render web services set PORT automatically. If a service-specific HTTP port is
# not set, the apps will fall back to PORT.
PORT=10000

MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_URI=
DB_SYNC=false

AUTH_MONGODB_DB=oyana_auth
USER_MONGODB_DB=oyana_user
DRIVER_MONGODB_DB=oyana_driver

AUTH_MONGODB_URI=
USER_MONGODB_URI=
DRIVER_MONGODB_URI=